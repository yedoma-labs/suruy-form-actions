{
  "name": "@yedoma-labs/suruy-form-actions",
  "version": "0.1.0",
  "description": "Type-safe form library for React Server Actions with progressive enhancement",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-push": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "react",
    "forms",
    "server-actions",
    "progressive-enhancement",
    "typescript",
    "validation",
    "nextjs"
  ],
  "author": "yedoma-labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yedoma-labs/suruy-form-actions.git"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "simple-git-hooks": "^2.13.1",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
