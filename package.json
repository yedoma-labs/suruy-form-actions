{
  "name": "@yedoma-labs/suruy-form-actions",
  "version": "0.1.0",
  "description": "Type-safe form library for React Server Actions with progressive enhancement",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "forms",
    "server-actions",
    "progressive-enhancement",
    "typescript",
    "validation",
    "nextjs"
  ],
  "author": "yedoma-labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yedoma-labs/suruy-form-actions.git"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
